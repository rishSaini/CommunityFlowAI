# ============================================
# CCH Ordering & Dispatch System
# Copy this file to .env and fill in real values
# ============================================

# JWT Authentication — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_generate_a_random_hex_string

# OpenRouter AI Gateway — get key at https://openrouter.ai/keys
# Single key gives access to Claude, GPT, Gemini, Llama, and hundreds more
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# Google Maps Platform — https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Directions API, Geocoding API
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Twilio SMS + Voice — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Travel buffer (minutes) added before departure time — configurable in admin settings
TRAVEL_BUFFER_MINUTES=15
